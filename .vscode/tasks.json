{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Game",
            "type": "shell",
            "command": "cd \"${workspaceFolder}\"; Remove-Item src/*.class -ErrorAction SilentlyContinue; javac src/*.java; if ($?) { java src.Main }",
            "options": {
                "shell": {
                    "executable": "powershell.exe"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}